# PostgreSQL
POSTGRES_DB=certifactory
POSTGRES_USER=certifactory
POSTGRES_PASSWORD=change-me-strong-password

# Backend
PKI_MASTER_KEY=change-me-to-a-secure-32-byte-key
JWT_SECRET_KEY=change-me-to-a-random-secret

# Ports (optional, defaults to 80/443)
HTTP_PORT=80
HTTPS_PORT=443

# SSL Certificates (optional)
# To use your own certs, set these and mount the directory:
#   SSL_CERT_DIR=./certs
#   SSL_CERT_PATH=/etc/nginx/certs/cert.pem
#   SSL_KEY_PATH=/etc/nginx/certs/key.pem
# If not set, a self-signed certificate is generated automatically.
